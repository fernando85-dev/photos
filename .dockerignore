# Git files
.git/
.gitignore

# Python cache and virtual environments
__pycache__/
*.pyc
*.pyo
*.pyd
.Python
env/
venv/
*.egg-info/
.env

# Test related files and directories
tests/
# test_data_temp/ or tests/test_data/ are generated by tests and should not be included
test_data_temp/
app/tests/test_data_temp/
# Coverage files
.coverage
coverage.xml

# IDE and editor specific files
.vscode/
.idea/
*.sublime-project
*.sublime-workspace

# OS specific files
.DS_Store
Thumbs.db

# Local databases and generated files (let the container create fresh ones)
# These paths are relative to the Docker build context (project root)
*.db
*.db-journal
uploads/*
app/tmp_zip_files/*
app/database.db
app/database.db-journal

# If uploads/ is empty and gitignored, an empty uploads/ directory might be copied.
# To ensure it's always excluded from image if it contains local dev files:
# uploads/*
# !uploads/.placeholder
# (If you use a placeholder to keep the directory in git)
# For this project, uploads/ is created by init_db() if it doesn't exist.

# Docker files themselves (they are not needed inside the image)
Dockerfile
.dockerignore

# README or other documentation files not needed by the running app
README.md
docs/
